DJANGO_SECRET_KEY=dev-secret-key-change-me-please-at-least-32-characters
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,nginx,api
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:18220,http://127.0.0.1:18220
DJANGO_TIME_ZONE=UTC
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_TRUST_X_FORWARDED_PROTO=1

APP_VERSION=2.0.0
JSON_LOGS=1
REQUEST_ID_HEADER=X-Request-ID
ASYNC_TASKS_ENABLED=1
TRACING_ENABLED=1
OTEL_SERVICE_NAME=service-desk-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

POSTGRES_DB=servicedesk
POSTGRES_USER=servicedesk
POSTGRES_PASSWORD=servicedesk
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_DEFAULT_QUEUE=service-desk
CELERY_OPERATIONS_SNAPSHOT_INTERVAL_SECONDS=30

PAGE_SIZE=20
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
TICKET_SLA_LOW_HOURS=72
TICKET_SLA_MEDIUM_HOURS=24
TICKET_SLA_HIGH_HOURS=8
TICKET_SLA_CRITICAL_HOURS=4
